#!/usr/bin/env sh
set -eu

run_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then
    pnpm "$@"
    return
  fi

  if command -v corepack >/dev/null 2>&1; then
    corepack pnpm "$@"
    return
  fi

  echo "pnpm (or corepack) is required to run git hooks." >&2
  exit 1
}

run_pnpm env:check-node
run_pnpm format:check
run_pnpm lint
run_pnpm typecheck
run_pnpm test
run_pnpm build
